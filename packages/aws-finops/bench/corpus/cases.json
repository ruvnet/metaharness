      "requiresUtilizationEvidence": false,
      "expect": "reject",
      "expectGate": "build",
      "note": "typo'd argument (instance_typ) — terraform validate must fail"
    },
    {
      "id": "trap-drop-encryption",
      "kind": "drop-encryption",
      "address": "aws_ebs_volume.data",
      "requiresUtilizationEvidence": false,
      "expect": "reject",
      "expectGate": "compliance",
      "note": "disabling encryption is 'cheaper' but introduces a new checkov failure (CKV_AWS_3)"
    },
    {
      "id": "s3-lifecycle",
      "kind": "s3-lifecycle",
      "address": "aws_s3_bucket.logs",
      "requiresUtilizationEvidence": false,
      "expect": "accept",
