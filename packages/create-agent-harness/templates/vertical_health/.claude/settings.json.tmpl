{
  "permissions": {
    "allow": [
      "Bash(npx {{name}}*)",
      "mcp__{{name}}__*",
      "mcp__health_kb__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "mcpServers": {
    "{{name}}": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "start"
      ]
    },
    "health_kb": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "health"
      ]
    }
  }
}
