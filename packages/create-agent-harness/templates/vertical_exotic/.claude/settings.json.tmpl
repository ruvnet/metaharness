{
  "permissions": {
    "allow": [
      "Bash(npx {{name}}*)",
      "mcp__{{name}}__*",
      "mcp__evolution_log__*",
      "mcp__federation__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf*)"
    ]
  },
  "mcpServers": {
    "{{name}}": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "start"
      ]
    },
    "evolution_log": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "evolution"
      ]
    },
    "federation": {
      "command": "npx",
      "args": [
        "-y",
        "{{name}}@latest",
        "mcp",
        "federate"
      ]
    }
  }
}
